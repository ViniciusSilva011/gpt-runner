  "info": {
    "title": "GPT Container Experiment API",
    "description": "Creates temporary Docker containers for code experiments.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [
    {
      "url": "https://sandbox.floow.site"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "API key",
        "type": "http"
      }
    },
    "schemas": {
      "CreateJobDto": {
        "type": "object",
        "properties": {
          "repo_url": {
            "type": "string",
            "description": "Optional git repository URL to clone before running commands.",
            "example": "https://github.com/pallets/flask.git"
          },
          "branch": {
            "type": "string",
            "description": "Optional branch, tag, or ref to clone.",
            "example": "main"
          },
          "commands": {
            "description": "Shell commands to run inside the temporary container.",
            "example": [
              "python3 --version",
              "python3 -m venv .venv",
              ". .venv/bin/activate && pip install -e .",
              ". .venv/bin/activate && pytest"
            ],
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "timeout_seconds": {
            "type": "number",
            "description": "Maximum runtime in seconds.",
            "default": 300,
            "maximum": 900
          },
          "network": {
            "type": "string",
            "description": "Whether the runner container should have network access.",
            "enum": [
              "on",
              "off"
            ],
            "default": "on"
          },
          "root": {
            "type": "boolean",
            "description": "Run as root inside the disposable container. Needed for apt install. Riskier.",
            "default": false
          }
        },
        "required": [
          "commands"
        ]
      }
    }
  }
}
