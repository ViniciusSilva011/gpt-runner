                          "success",
                          "failed",
                          "timeout",
                          "deleted"
                        ]
                      },
                      "created_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "updated_at": {
                        "type": "string",
                        "format": "date-time"
                      },
                      "return_code": {
                        "type": "integer",
                        "nullable": true
                      }
                    },
                    "required": [
                      "job_id",
                      "status",
                      "created_at",
                      "updated_at",
                      "return_code"
                    ]
                  }
